{
  "name": "agenthub",
  "version": "0.5.1",
  "description": "AgentHub - 多 Agent 协同桌面工作台",
  "main": "out/main/index.js",
  "author": {
    "name": "AgentHub Team",
    "email": "team@agenthub.dev"
  },
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev --watch",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "npm run build && electron-builder --win --publish never",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "build:mac": "npm run build && electron-builder --mac --publish never",
    "build:linux": "npm run build && electron-builder --linux --publish never",
    "build:all": "npm run build && electron-builder -mw --publish never",
    "unpack": "electron-builder --dir"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^5.4.8",
    "vitest": "^4.1.7"
  },
  "build": {
    "appId": "dev.agenthub.desktop",
    "productName": "AgentHub",
    "copyright": "Copyright (c) 2026 AgentHubTeam",
    "buildVersion": "0.5.1",
    "files": [
      "out/**/*",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,*.d.ts,*.map,test/**,__tests__/**,*.test.*,*.spec.*}",
      "!**/node_modules/.bin",
      "!**/*.{md,markdown}",
      "!**/node_modules/*/{.bin,.cache,build,docs,example,examples,test,tests,__tests__,coverage,*.d.ts.map,*.d.ts}"
    ],
    "extraResources": [
      {
        "from": "build/installerSidebar.bmp",
        "to": "build/installerSidebar.bmp"
      },
      {
        "from": "LICENSE",
        "to": "LICENSE"
      }
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "protocols": [
      {
        "name": "AgentHub Protocol",
        "schemes": [
          "agenthub"
        ]
      }
    ],
    "fileAssociations": [
      {
        "ext": "agenthub-chat",
        "name": "AgentHub Chat Export",
        "role": "Editor"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "publisherName": "AgentHubTeam",
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": false,
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": false,
      "shortcutName": "AgentHub",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeader": "build/installerSidebar.bmp",
      "installerSidebar": "build/installerSidebar.bmp",
      "include": "build/installer.nsh",
      "displayLanguageSelector": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "darkModeSupport": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSHumanReadableCopyright": "Copyright (c) 2026 AgentHubTeam. All rights reserved.",
        "CFBundleURLSchemes": [
          "agenthub"
        ],
        "LSApplicationCategoryType": "public.app-category.developer-tools",
        "LSEnvironment": {
          "AGENTHUB_VERSION": "${version}"
        }
      },
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon-linux.png",
      "category": "Development",
      "vendor": "AgentHubTeam",
      "maintainer": "AgentHubTeam <team@agenthub.dev>",
      "description": "AgentHub - 多 Agent 协同桌面工作台",
      "desktop": {
        "entry": {
          "Name": "AgentHub",
          "Comment": "多 Agent 协同桌面工作台",
          "Categories": "Development;Utility;"
        },
        "MimeType": "x-scheme-handler/agenthub;"
      },
      "artifactName": "${productName}-${version}.${ext}"
    },
    "publish": null,
    "compression": "normal",
    "asar": true,
    "afterPack": null
  },
  "homepage": "https://agenthub.dev",
  "bugs": "https://github.com/agenthub/agenthub/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/agenthub/agenthub.git"
  }
}
