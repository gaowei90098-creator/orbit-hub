{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dashboard",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "dashboard", "run", "dev", "--", "--port", "5180", "--strictPort"],
      "port": 5180
    },
    {
      "name": "snake",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),p=require('path').join(process.cwd(),'.preview-snake','index.html');http.createServer((q,s)=>{s.writeHead(200,{'Content-Type':'text/html; charset=utf-8'});s.end(fs.readFileSync(p,'utf8'))}).listen(5190,'127.0.0.1',()=>console.log('snake on 5190'))"],
      "port": 5190
    }
  ]
}
